# 小念 XiaoNian — 环境配置示例
# 复制为 .env 后填入你的密钥。所有数据与密钥仅保存在本机。

# ===== 默认使用的模型 provider：minimax | deepseek | mimo | mock =====
XIAONIAN_PROVIDER=minimax

# ===== MiniMax（主力）=====
# coding 套餐 key（sk-cp-...）走 Anthropic 兼容端点（与 OpenAI 文本接口是不同额度池）
MINIMAX_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_PROTOCOL=anthropic
MINIMAX_MODEL=MiniMax-M2

# ===== DeepSeek（高性价比备选）=====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== 小米 MiMo（生态加分，OpenAI 兼容）=====
MIMO_API_KEY=
MIMO_BASE_URL=https://api.example-mimo.xiaomi.com/v1
MIMO_MODEL=mimo

# ===== 服务 =====
XIAONIAN_HOST=127.0.0.1
XIAONIAN_PORT=8765

# ===== 安全/隐私 =====
# 写操作（删除/移动/执行命令/下单）是否需要两步确认
XIAONIAN_REQUIRE_CONFIRM=true
# 上云前 PII 脱敏
XIAONIAN_REDACT_PII=true

# ===== 主动关心引擎 =====
XIAONIAN_PROACTIVE_ENABLED=true
# 静默时段（不主动打扰），24h
XIAONIAN_QUIET_START=23
XIAONIAN_QUIET_END=8

# ===== 用户 =====
XIAONIAN_USER_ID=master
XIAONIAN_USER_NAME=主人
